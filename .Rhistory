devtools::document()
devtools::build()
library(devtools)
library(usethis)
library(roxygen2)
devtools::document()
devtools::build()
library(devtools)
library(usethis)
library(roxygen2)
devtools::document()
devtools::build()
library(devtools)
library(usethis)
library(roxygen2)
devtools::document()
devtools::build()
library(devtools)
